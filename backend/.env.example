# Скопируй этот файл в .env и заполни значения.
# .env НИКОГДА не коммитится в git.

BOT_TOKEN=123456:ABC-DEF_your_token_here
WEBAPP_URL=https://your-app.vercel.app
API_PORT=8000
DB_PATH=cryptopocket.db
# COINGECKO_API_KEY=
# Для локальной отладки вне Telegram — разрешает пустой X-Init-Data (user_id=0).
# НИКОГДА не ставить true на проде.
ALLOW_EMPTY_INIT_DATA=false
