# Скопируй этот файл в .env и заполни значения.
# .env НИКОГДА не коммитится в git.

# Токен бота от @BotFather
BOT_TOKEN=123456:ABC-DEF_your_token_here

# URL фронтенда Mini App (после деплоя на Vercel), для /start кнопки
WEBAPP_URL=https://your-app.vercel.app

# Порт API (по умолчанию 8000)
API_PORT=8000

# (опционально) ключ CoinGecko, если перейдёшь на платный тариф
# COINGECKO_API_KEY=
